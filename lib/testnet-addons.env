# =============================================================================
# lib/testnet-addons.env — PUBLIC constants for the testnet opt-in add-ons
# (VPN admin SSH · healthcheck monitoring · centralized logging).
#
# Sourced transitively via lib/common.sh, so every setup/standalone script gets
# these. Everything here is PUBLIC: a WireGuard public key, public IPs, and a Loki
# push URL. The ONLY secret these features need is the per-operator obs ingest
# token — that is pasted at setup time (read -s) and is NEVER committed or stored
# in .node-meta.
#
# Plain `export`s ONLY (no `readonly`): this file is safe to source more than once
# under `set -e`. Keep values in sync with their upstream source-of-truth, noted
# per-block below. See docs/testnet-addons.md.
# =============================================================================

export TESTNET_ADDONS_VERSION="1.0.0"

# --- WireGuard admin overlay — hub coordinates (PUBLIC) -----------------------
# Source of truth: lib/wgvpn/hub-coordinates.env (vendored verbatim from
# adiri-genesis/common/wgvpn/hub/hub-coordinates.env). setup-vpn.sh consumes the
# vendored file directly; these namespaced copies are for display/validation only.
export TN_WG_HUB_ENDPOINT="34.20.198.253:51820"
export TN_WG_HUB_PUBKEY="hqIDskzaOS5t6DE91VX+V9Z4NJjKlNufl4kQr/KuF1k="

# --- WireGuard overlay addressing --------------------------------------------
# The overlay spans 10.100.<net>.<idx>. Reserved /24 nets must NEVER be used by an
# external operator: 0=hub, 1=adiri core (all 5 validators), 2=devnet, 9=maintainers.
# External operators are assigned a /32 in the external band by the core team.
export TN_OVERLAY_CIDR="10.100.0.0/16"
export TN_OVERLAY_RESERVED_NETS="0 1 2 9"
export TN_OVERLAY_EXTERNAL_BAND_HINT="10.100.20.0/24"   # external band: nets 20+, one /32 per node

# --- Kuma healthcheck monitor (PUBLIC source) --------------------------------
# The Telcoin Association uptime monitor that TCP-probes the node health port.
# Source of truth: adiri-genesis/config.sh HEALTHCHECK_MONITOR_SRC.
export TN_KUMA_SRC="104.155.184.201/32"
export TN_KUMA_PORT="43174"

# --- Centralized logging — Loki ingest (PUBLIC URL) --------------------------
# Authoritative testnet push endpoint (adiri-genesis/config.sh OBS_HOSTNAME =
# obs.adiri.telcoin.network). NB: the obs.telcoin.network fallback in the GCP
# reference script (start-validator-node.sh) is STALE — do not use it.
export OBS_PUSH_URL_TESTNET="https://obs.adiri.telcoin.network/loki/api/v1/push"

# Alloy runtime: Docker sidecar image for docker installs; pinned native version
# (apt pin / tarball fallback) for binary/source installs.
export TN_ALLOY_IMAGE="grafana/alloy:v1.5.1"
export TN_ALLOY_NATIVE_VERSION="1.5.1"
